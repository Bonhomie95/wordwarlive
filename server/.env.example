# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
# Comma-separated list of allowed origins for CORS. In production, lock this
# down to your real client origins. "*" works for local Expo dev.
CORS_ORIGINS=*

# ─── Postgres ────────────────────────────────────────────────────────────────
# Default values match docker-compose.yml.
DATABASE_URL=postgresql://wordwar:wordwar@localhost:5432/wordwar

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-me-with-a-long-random-string
# 30 days
JWT_EXPIRES_IN=30d

# Google Sign-In — get from Google Cloud Console (OAuth 2.0 Client IDs).
# You'll typically have one ID per platform; the server validates whichever
# id_token the client sends, so list every client ID that should be accepted.
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com

# Apple Sign-In — your app's bundle ID is the audience the server checks.
APPLE_BUNDLE_ID=dev.bonhomieinc.wordwar

# ─── Groq ────────────────────────────────────────────────────────────────────
# Used for the bot opponent and daily-word curation.
# Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Game tuning ─────────────────────────────────────────────────────────────
MATCH_DURATION_SECONDS=360
MATCHMAKING_BOT_AFTER_SECONDS=20
MATCHMAKING_RANGE_START=200
MATCHMAKING_RANGE_EXPANDED=500
GUESS_RATE_LIMIT_MS=2000

# ─── AdMob ───────────────────────────────────────────────────────────────────
# The SSV (Server-Side Verification) URL is configured in the AdMob dashboard
# under each rewarded ad unit's Server-side verification settings.
# It must be: https://YOUR-DOMAIN/api/ads/ssv
# AdMob's signing keys are fetched automatically from gstatic.com — no key
# config is needed on this side.
