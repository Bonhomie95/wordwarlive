# Expo prefixes EXPO_PUBLIC_ env vars are exposed to the client. DO NOT put
# anything secret in here.

# Point this at your dev machine's LAN IP so a phone on the same Wi-Fi can
# reach the server. http://localhost:4000 only works on simulators.
EXPO_PUBLIC_API_URL=http://192.168.1.100:4000

# Google Sign-In OAuth client IDs (one per platform you ship to).
# These map to the IDs you list in the server's GOOGLE_CLIENT_IDS.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# AdMob ad unit IDs. In development the app uses Google's test IDs
# automatically; the values below are only read in production builds.
# Get them from the AdMob console (one rewarded + one interstitial per
# platform). The app IDs themselves are configured in app.json under the
# react-native-google-mobile-ads plugin block.
EXPO_PUBLIC_ADMOB_REWARDED_IOS_ID=ca-app-pub-XXXXXXXXXXXX/REWARDED_IOS
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID_ID=ca-app-pub-XXXXXXXXXXXX/REWARDED_ANDROID
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS_ID=ca-app-pub-XXXXXXXXXXXX/INTERSTITIAL_IOS
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID_ID=ca-app-pub-XXXXXXXXXXXX/INTERSTITIAL_ANDROID
EXPO_PUBLIC_ADMOB_BANNER_IOS_ID=ca-app-pub-XXXXXXXXXXXX/BANNER_IOS
EXPO_PUBLIC_ADMOB_BANNER_ANDROID_ID=ca-app-pub-XXXXXXXXXXXX/BANNER_ANDROID
